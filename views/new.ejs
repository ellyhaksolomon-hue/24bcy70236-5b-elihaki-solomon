<!DOCTYPE html>
<html>
<head>
    <title>Add Student</title>
</head>
<body>

<h1>Add New Student</h1>

<form action="/students" method="POST">
    
    <label>Name:</label>
    <input type="text" name="name" required>

    <br><br>

    <label>Roll:</label>
    <input type="number" name="roll" required>

    <br><br>

    <button type="submit">Add Student</button>

</form>

</body>
</html>